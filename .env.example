EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=https://eu.i.posthog.com

# Base URL for the app's own API routes (e.g. /api/cv-feedback).
# On native builds this must point at a hosted backend (EAS Hosting).
# In the Expo dev server it falls back to the dev machine origin automatically,
# so you can leave this blank during local development.
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_ENABLE_VOICE_COACH=false

# Server-only AI provider keys. Do not prefix these with EXPO_PUBLIC_.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Stream Video & Audio authentication. Do not expose in the mobile app.
STREAM_API_KEY=
STREAM_API_SECRET=

# Voice agent bridge used by /api/start-ai-coach-session and /api/stop-ai-coach-session.
# Keep these server-side only.
VISION_AGENT_URL=http://127.0.0.1:8000
VISION_AGENT_SHARED_SECRET=

# Optional: dedicated realtime model for the Python voice-agent service.
# If omitted, the service uses GEMINI_MODEL and falls back to a live-compatible model automatically.
VISION_AGENT_GEMINI_MODEL=gemini-3.1-flash-live-preview

